{
  "redirects": [
    {
      "source": "/traxxo/admin",
      "destination": "https://admin.traxxo.ai",
      "permanent": true
    },
    {
      "source": "/traxxo/project/:slug",
      "destination": "https://admin.traxxo.ai/project/:slug",
      "permanent": true
    },
    {
      "source": "/traxxo/project/:slug/google",
      "destination": "https://admin.traxxo.ai/project/:slug/google",
      "permanent": true
    },
    {
      "source": "/traxxo/project/:slug/ga4",
      "destination": "https://admin.traxxo.ai/project/:slug/ga4",
      "permanent": true
    },
    {
      "source": "/traxxo/project/:slug/semrush",
      "destination": "https://admin.traxxo.ai/project/:slug/semrush",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/project/:slug",
      "destination": "/dashboard.html"
    },
    {
      "source": "/project/:slug/google",
      "destination": "/google-data.html"
    },
    {
      "source": "/project/:slug/ga4",
      "destination": "/ga4-data.html"
    },
    {
      "source": "/project/:slug/semrush",
      "destination": "/semrush-data.html"
    }
  ]
}
